            display-name = "Num";
            bindings = <
   &kp ESC      &kp FSLH     &mt F1 N1    &mt F2 N2     &mt F3 N3     &mt F4 EQUAL  &kp LPAR     &kp RPAR     &kp UP       &kp LBKT     &kp RBKT      &kp BSLH
   &kp TAB      &kp ASTRK    &mt F5 N4    &mt F6 N5     &mt F7 N6     &mt F8 PLUS   &kp EXCL     &kp LEFT     &kp DOWN     &kp RIGHT    &kp GRAVE     &kp SQT
