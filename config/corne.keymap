                                          &kp LCTRL      &kp LSHFT     &kp SPACE     &kp BSPC     &tog NUM     &lt FUN RET
            >;
        };

        fun_layer {
// Left: media controls (row 1) + brightness/volume ramp (row 2) + utilities (row 3).
